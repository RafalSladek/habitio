{
  "name": "habitio",
  "version": "1.0.10",
  "description": "A habit tracker app — offline-first PWA, no account required.",
  "main": "index.html",
  "scripts": {
    "test": "playwright test",
    "test:desktop": "playwright test --project=\"Desktop Chromium\"",
    "test:mobile": "playwright test --project=\"Pixel 5 Chromium\"",
    "test:tablet": "playwright test --project=\"Tablet Firefox\"",
    "test:iphone": "playwright test --project=\"iPhone 12 Safari\"",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "badges:generate": "node scripts/generate-badges.js",
    "screenshots": "node scripts/take-screenshots.js",
    "gif": "node scripts/generate-gif.js",
    "format": "prettier --write \"*.{js,css,html,json}\"",
    "format:check": "prettier --check \"*.{js,css,html,json}\"",
    "precommit": "yarn format:check && yarn test && echo '\\n✅ Pre-commit checks passed'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RafalSladek/habitio.git"
  },
  "keywords": [],
  "author": "Rafal Sladek",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/RafalSladek/habitio/issues"
  },
  "homepage": "https://github.com/RafalSladek/habitio#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "prettier": "^3.8.3",
    "v8-to-istanbul": "^9.3.0"
  }
}
